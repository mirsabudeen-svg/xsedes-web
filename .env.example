# Anthropic Messages API key — Concierge (Workers) + admin agent Actions
ANTHROPIC_API_KEY=

# Canonical deployed site URL (no trailing slash) — SEO agent page fetches
SITE_URL=

# Optional contact form delivery (Resend). Without these, /api/contact logs only.
RESEND_API_KEY=
CONTACT_INBOX=
# Verified sender address in Resend (defaults to onboarding@resend.dev)
CONTACT_FROM=
