# Anthropic Messages API key — Concierge, Content Manager, Blog, SEO, Social agents
ANTHROPIC_API_KEY=

# GitHub fine-grained token (Contents + Pull requests write) — agents that open PRs
GITHUB_TOKEN=

# GitHub repo as owner/name — PR target for content/blog/social agents
GITHUB_REPO=

# Shared secret for admin-only agent routes (Authorization: Bearer …)
ADMIN_SECRET=

# Canonical deployed site URL (no trailing slash) — SEO agent page fetches
SITE_URL=
